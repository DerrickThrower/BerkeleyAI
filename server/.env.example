# ── VibeDocs AI server — environment ───────────────────────────────────────
# Copy to server/.env. This is the file the server actually loads at startup.
#
# NOTE: With NO API keys set, the system automatically falls back to a
# deterministic MOCK adapter so the full prompt -> arbitrate -> merge -> apply
# loop runs end-to-end offline. Set keys to use the real models.

# Anthropic — Claude orchestration (arbitration/routing) + a model option.
# If unset, the mock adapter is used for any "claude" request.
ANTHROPIC_API_KEY=

# OpenAI — GPT as the second provider behind the same execute_prompt() adapter.
# If unset, "gpt" requests fall back to the mock adapter.
OPENAI_API_KEY=

# Redis connection (pub/sub presence, streams ledger, hash file store + locks).
REDIS_URL=redis://localhost:6379

# WebSocket / HTTP server port.
PORT=8787

# Model ids used by the adapters.
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# Arize Phoenix OTLP/HTTP trace endpoint (matches docker-compose phoenix:6006).
PHOENIX_OTLP_ENDPOINT=http://localhost:6006/v1/traces

# Master switch for OpenTelemetry tracing export to Phoenix.
TRACING_ENABLED=true

# Arbitration window (ms): prompts arriving within this window on the same room
# are batched so concurrent intents can be classified/merged together.
ARB_WINDOW_MS=1400
